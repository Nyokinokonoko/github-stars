# Copy to .env and fill in. .env is git-ignored.

# GitHub account whose stars are catalogued.
GH_USER=nyokinokonoko

# Optional: a GitHub token raises the API rate limit from 60/hr to 5000/hr.
# A classic token with no scopes (or a fine-grained token with public read)
# is enough — we only read public starred repos.
GITHUB_TOKEN=

# Required for categorizing new stars. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional overrides (defaults shown).
# OPENROUTER_MODEL=google/gemini-3-flash-preview
